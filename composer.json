{
     "name": "glial/glial",
     "description": "A HMVC PHP framework (include CLI mode) made for high volumetry & batch process",
     "keywords": ["framework"],
     "type": "library",
     "license": "MIT",
     "authors": [
         {
             "name": "Aurélien LEQUOY",
             "email": "aurelien.lequoy@esysteme.com",
             "homepage": "http://www.glial-framework-php.org/",
             "role": "Creator"
         }
     ],
     "require": {
         "php": ">=8.2",
         "monolog/monolog": "1.*",
	 "phpseclib/mcrypt_compat": "*"
     },
     "autoload": {
         "psr-4": {
             "Glial\\": "Glial/"
             },
         "classmap": ["lib/"]
     },
     "minimum-stability": "stable",
     "scripts": {
  	"pre-install-cmd": [
  	  "php ./glial install update"
  	]
	}
 }
